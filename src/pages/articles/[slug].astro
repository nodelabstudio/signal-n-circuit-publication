---
import PublicationLayout from '../../layouts/PublicationLayout.astro';
import { getPublicationPost, getPublicationPosts } from '../../lib/publication';

export async function getStaticPaths() {
  const posts = await getPublicationPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = slug ? await getPublicationPost(slug) : undefined;

if (!post) {
  return Astro.redirect('/articles');
}
---

<PublicationLayout title={post.title} description={post.excerpt}>
  <article class='article'>
    <header class='article-head'>
      <div class='headline-band'>
        <div>
          <p class='kicker'><a class='category-link' href={`/category/${post.category}/`}>{post.category.replace(/-/g, ' ')}</a></p>
          <h1>{post.title}</h1>
          <p class='deck'>{post.excerpt}</p>
        </div>
        <div class='headline-meta card'>
          <span>{post.type}</span>
          <span>{post.author}</span>
          <span>{post.date}</span>
        </div>
      </div>
      <div class='tag-row'>
        {
          post.tags.map((tag) => (
            <a class='pill' href={`/tag/${tag}/`}>{tag}</a>
          ))
        }
      </div>
    </header>

    <section class='content-wrap'>
      <div class='prose card body-card'>
        <div class='article-rail'>
          <span>Lead analysis</span>
          <strong>{post.category.replace(/-/g, ' ')}</strong>
        </div>
        <p class='standfirst'>The commercial shape of AI agents is getting clearer: long-term value concentrates around installation, maintenance, oversight, and the human-readable systems that make automation survivable in the field.</p>
        {post.body?.split('\n\n').map((paragraph) => <p>{paragraph}</p>)}
      </div>

      <aside class='sidebar'>
        <div class='card side-block brief-block'>
          <p class='kicker'>Article brief</p>
          <p>Why it matters</p>
          <strong>The interesting business is moving from demo appeal toward maintained systems customers can actually rely on.</strong>
        </div>
        <div class='card side-block'>
          <p class='kicker'>Sources</p>
          <ul>
            {
              post.sources.map((source) => (
                <li><a href={source} target='_blank' rel='noreferrer'>{source}</a></li>
              ))
            }
          </ul>
        </div>
        <div class='card side-block signal-block'>
          <p class='kicker'>Signal points</p>
          <ul>
            <li>Services are becoming the moat, not the demo.</li>
            <li>Reliability beats novelty when workflows reach production.</li>
            <li>Operational visibility matters as much as model capability.</li>
          </ul>
        </div>
        <div class='card side-block'>
          <p class='kicker'>Disclosure</p>
          <p>This article was produced with AI assistance and reviewed for accuracy before publication.</p>
        </div>
      </aside>
    </section>
  </article>
</PublicationLayout>

<style>
  .article {
    display: grid;
    gap: 1.5rem;
  }

  .article-head {
    display: grid;
    gap: 1rem;
  }

  .headline-band {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(220px, 0.55fr);
    gap: 1rem;
    align-items: start;
  }

  .headline-band h1 {
    max-width: 12ch;
    font-size: clamp(2.9rem, 5vw, 4.8rem);
  }

  .headline-meta {
    padding: 1rem;
    display: grid;
    gap: 0.5rem;
    align-content: start;
    color: rgb(var(--muted));
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
  }

  .category-link {
    text-decoration: none;
    color: inherit;
  }

  .deck {
    font-size: 1.18rem;
    color: rgb(var(--muted));
    max-width: 58ch;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .content-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(260px, 0.8fr);
    gap: 1.25rem;
    align-items: start;
  }

  .body-card {
    position: relative;
    padding: 1.8rem 1.8rem 1.5rem;
  }

  .article-rail {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.2rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid rgba(var(--border), 0.7);
    color: rgb(var(--muted));
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
  }

  .standfirst {
    font-size: 1.26rem;
    line-height: 1.72;
    color: rgb(var(--ink));
    max-width: 34em;
  }

  .body-card p {
    margin-bottom: 1.35rem;
    max-width: 39em;
    font-size: 1.12rem;
    line-height: 1.82;
  }

  .sidebar {
    display: grid;
    gap: 1rem;
  }

  .side-block {
    padding: 1rem;
  }

  .brief-block {
    display: grid;
    gap: 0.5rem;
    background: rgba(var(--surface-strong), 0.62);
  }

  .brief-block p {
    color: rgb(var(--muted));
  }

  .brief-block strong {
    line-height: 1.3;
  }

  .signal-block ul,
  .side-block ul {
    margin: 0.8rem 0 0;
    padding-left: 1.1rem;
  }

  .side-block li + li {
    margin-top: 0.5rem;
  }

  @media (max-width: 980px) {
    .headline-band,
    .content-wrap {
      grid-template-columns: 1fr;
    }
  }
</style>
