---
interface Props {
  name: string;
  image: string;
  bio: string;
  size?: 'sm' | 'md';
}

const { name, image, bio, size = 'md' } = Astro.props;
const initials = name
  .split(' ')
  .map((part) => part[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();
---

<div class={`author-block ${size}`}>
  {image ? (
    <img class='portrait' src={image} alt={name} loading='lazy' />
  ) : (
    <span class='portrait fallback' aria-hidden='true'>{initials}</span>
  )}
  <div class='copy'>
    <span class='label'>By</span>
    <span class='name'>{name}</span>
    <span class='bio'>{bio}</span>
  </div>
</div>

<style>
  .author-block {
    display: flex;
    align-items: center;
    gap: 0.95rem;
    min-width: 0;
    color: rgb(var(--author-ink, 26, 26, 26));
  }

  .author-block.sm {
    gap: 0.78rem;
  }

  .portrait {
    width: 48px;
    height: 48px;
    border-radius: 999px;
    object-fit: cover;
    flex-shrink: 0;
    border: 1px solid rgba(var(--author-border, 232, 228, 223), 0.95);
    background: rgb(var(--author-avatar-bg, 255, 255, 255));
  }

  .author-block.sm .portrait {
    width: 40px;
    height: 40px;
  }

  .fallback {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: rgb(var(--author-ink, 26, 26, 26));
    background: rgba(var(--author-avatar-bg, 250, 248, 245), 0.95);
  }

  .copy {
    display: grid;
    gap: 0.14rem;
    min-width: 0;
  }

  .label {
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgb(var(--author-muted, 107, 107, 107));
  }

  .name {
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.15;
    color: rgb(var(--author-ink, 26, 26, 26));
  }

  .bio {
    font-size: 0.8rem;
    line-height: 1.42;
    color: rgb(var(--author-muted, 107, 107, 107));
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    max-width: 34ch;
  }

  .author-block.sm .label {
    font-size: 0.58rem;
  }

  .author-block.sm .name {
    font-size: 0.88rem;
  }

  .author-block.sm .bio {
    font-size: 0.76rem;
    max-width: 28ch;
  }
</style>
