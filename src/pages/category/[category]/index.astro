---
import ArticleCard from '../../../../src/components/ArticleCard.astro';
import PublicationLayout from '../../../layouts/PublicationLayout.astro';
import { NAV_CATEGORIES } from '../../../consts';
import { getPublicationPosts } from '../../../lib/publication';

export const prerender = true;

export async function getStaticPaths() {
  return NAV_CATEGORIES.map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.params;
const posts = await getPublicationPosts();
const filteredPosts = posts.filter((post) => post.category === category);

if (!category) {
  return Astro.redirect('/articles');
}
---

<PublicationLayout
  title={`Category: ${category.replace(/-/g, ' ')}`}
  description={`Publication archive for ${category.replace(/-/g, ' ')}.`}
>
  <section class='archive-head'>
    <p class='kicker'>Category archive</p>
    <h1>{category.replace(/-/g, ' ')}</h1>
    <p>
      Focused coverage for this lane of the publication.
    </p>
  </section>

  <section class='archive-tools card'>
    <div>
      <p class='kicker'>Lane status</p>
      <strong>{filteredPosts.length > 0 ? 'Active coverage' : 'Planned coverage'}</strong>
    </div>
    <div>
      <p class='kicker'>Story count</p>
      <strong>{filteredPosts.length}</strong>
    </div>
    <div>
      <p class='kicker'>Editorial use</p>
      <strong>{filteredPosts.length > 0 ? 'Archive + discovery' : 'Roadmap signal'}</strong>
    </div>
  </section>

  {
    filteredPosts.length > 0 ? (
      <section class='archive-grid'>
        {filteredPosts.map((post) => <ArticleCard post={post} />)}
      </section>
    ) : (
      <section class='empty card'>
        <div class='empty-media' aria-hidden='true'></div>
        <div class='empty-copy'>
          <p class='kicker'>Planned lane</p>
          <h2>No stories published here yet</h2>
          <p>
            This coverage lane is currently quiet while new reporting is in development. New stories will appear here as they are published.
          </p>
          <p>
            For now, browse the <a href='/articles/'>current article archive</a> or return to the <a href='/'>front page</a>.
          </p>
        </div>
      </section>
    )
  }
</PublicationLayout>

<style>
  .archive-head {
    display: grid;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
    max-width: 70ch;
  }

  .archive-head h1 {
    font-size: clamp(3rem, 6vw, 5.4rem);
    max-width: 11ch;
  }

  .archive-head p:last-child {
    color: rgb(var(--muted));
    font-size: 1.08rem;
    line-height: 1.65;
    max-width: 55ch;
  }

  .archive-tools {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    padding: 1rem 1.15rem;
    margin-bottom: 1rem;
  }

  .archive-tools div {
    display: grid;
    gap: 0.25rem;
  }

  .archive-tools strong {
    font-family: 'Playfair Display', Georgia, 'Times New Roman', serif;
    font-size: 1.35rem;
    line-height: 1.1;
  }

  .archive-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  @media (min-width: 1400px) {
    .archive-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .empty {
    overflow: hidden;
    border-radius: 0;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .empty:hover {
    transform: translateY(-4px);
    border-color: rgba(var(--accent), 0.18);
    box-shadow: 0 28px 70px rgba(var(--shadow), 0.12);
  }

  .empty-media {
    aspect-ratio: 16 / 9;
    background:
      linear-gradient(135deg, rgba(var(--ink), 0.78), rgba(var(--accent), 0.58)),
      radial-gradient(circle at 80% 20%, rgba(255,255,255,0.15), transparent 50%),
      repeating-linear-gradient(
        135deg,
        rgba(255,255,255,0.04) 0,
        rgba(255,255,255,0.04) 18px,
        transparent 18px,
        transparent 36px
      ), linear-gradient(135deg, rgba(var(--steel), 0.92), rgba(var(--accent-dark), 0.72));
    border-bottom: 1px solid rgba(var(--border), 0.85);
    display: grid;
    place-items: center;
  }

  .empty-media::after {
    content: 'Lane in development';
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.72rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.45);
  }

  .empty-copy {
    padding: 1.25rem 1.5rem 1.4rem;
    display: grid;
    gap: 0.85rem;
  }

  .empty-copy h2 {
    font-size: clamp(1.8rem, 2.8vw, 2.6rem);
    line-height: 1.05;
    letter-spacing: -0.035em;
  }

  .empty-copy p {
    color: rgb(var(--muted));
    line-height: 1.65;
    font-size: 0.96rem;
  }

  .empty-copy a {
    color: rgb(var(--accent));
    font-weight: 700;
    text-underline-offset: 0.2em;
    text-decoration: underline;
  }

  @media (max-width: 900px) {
    .archive-tools,
    .archive-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
