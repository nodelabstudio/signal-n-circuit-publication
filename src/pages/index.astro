---
import ArticleCard from '../components/ArticleCard.astro';
import AuthorBlock from '../components/AuthorBlock.astro';
import PublicationLayout from '../layouts/PublicationLayout.astro';
import { SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE } from '../consts';
import { getHomepagePublicationPosts, getPublicationPosts } from '../lib/publication';

const posts = await getHomepagePublicationPosts();
const allPosts = await getPublicationPosts();
const [hero, ...latestPosts] = posts;
---

<PublicationLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class='homepage'>
    <header class='issue-head'>
      <p class='kicker'>Signal &amp; Circuit</p>
      <h1>Editorial coverage for the AI economy.</h1>
      <p class='issue-copy'>
        {SITE_TAGLINE} Warm, sharp reporting on builders, operators, and the systems that have to survive real operating conditions.
      </p>
    </header>

    {hero && (
      <article class='hero-slot card'>
        <a class='hero-media' href={`/articles/${hero.slug}/`} aria-label={hero.title}>
          <img src={hero.image} alt={hero.title} loading='eager' />
        </a>

        <div class='hero-copy'>
          <div class='hero-topline'>
            <span class='hero-label'>Featured story</span>
            <a class='hero-category' href={`/category/${hero.category}/`}>
              {hero.category.replace(/-/g, ' ')}
            </a>
          </div>

          <h2 class='hero-title'>
            <a href={`/articles/${hero.slug}/`}>{hero.title}</a>
          </h2>

          <p class='hero-excerpt'>{hero.excerpt}</p>

          <div class='hero-meta'>
            <div
              class='hero-author'
              style='--author-ink: 255, 255, 255; --author-muted: 234, 229, 224; --author-border: 255, 255, 255; --author-avatar-bg: 255, 255, 255;'
            >
              <AuthorBlock name={hero.author} image={hero.authorImage} bio={hero.authorBio} size='md' />
            </div>
            <span class='hero-date'>{hero.date}</span>
          </div>
        </div>
      </article>
    )}

    <section class='latest-section'>
      <div class='section-head'>
        <div>
          <p class='kicker'>Latest</p>
          <h2>More from the archive</h2>
        </div>
        <div class='section-meta'>
          <p class='section-count'>{allPosts.length} stories in the archive</p>
          <a class='archive-link' href='/articles/'>Browse full archive</a>
        </div>
      </div>

      {
        latestPosts.length > 0 ? (
          <div class='latest-grid'>
            {latestPosts.map((post) => <ArticleCard post={post} />)}
          </div>
        ) : (
          <p class='empty-copy'>No additional stories yet. New coverage lands here as soon as it is published.</p>
        )
      }
    </section>

    <section class='newsletter-panel card'>
      <p class='kicker'>Newsletter</p>
      <h2>Signal &amp; Circuit</h2>
      <p class='newsletter-copy'>Practical dispatches on AI builders, operators, and the service economy. No fluff.</p>
      <form id='newsletter-form' class='newsletter-form'>
        <input id='newsletter-email' name='email' type='email' placeholder='you@example.com' required />
        <button id='newsletter-submit' type='submit'>Subscribe</button>
      </form>
      <p id='newsletter-status' class='newsletter-status' aria-live='polite'></p>
    </section>
  </section>

  <script is:inline>
    const form = document.getElementById('newsletter-form');
    const emailInput = document.getElementById('newsletter-email');
    const status = document.getElementById('newsletter-status');
    const submitBtn = document.getElementById('newsletter-submit');

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!emailInput || !status || !submitBtn) return;

      status.textContent = '';
      status.className = 'newsletter-status';
      submitBtn.setAttribute('disabled', 'true');
      submitBtn.textContent = 'Subscribing...';

      const body = new URLSearchParams({ email: emailInput.value.trim() });
      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body,
        });
        const data = await res.json().catch(() => ({}));

        if (res.ok) {
          status.textContent = 'Subscribed. Check your inbox for confirmation.';
          status.classList.add('ok');
          form.reset();
        } else {
          status.textContent = data.error || 'Could not subscribe right now.';
          status.classList.add('error');
        }
      } catch {
        status.textContent = 'Network error. Please try again.';
        status.classList.add('error');
      } finally {
        submitBtn.removeAttribute('disabled');
        submitBtn.textContent = 'Subscribe';
      }
    });
  </script>
</PublicationLayout>

<style>
  .homepage {
    display: grid;
    gap: 2rem;
  }

  .issue-head {
    display: grid;
    gap: 0.8rem;
    max-width: 58rem;
  }

  .issue-head h1 {
    max-width: 12ch;
    font-size: clamp(3rem, 6vw, 5.7rem);
    line-height: 0.96;
  }

  .issue-copy {
    max-width: 44rem;
    color: rgb(var(--muted));
    font-size: 1.08rem;
    line-height: 1.65;
  }

  .hero-slot {
    position: relative;
    overflow: hidden;
    border-radius: 0;
    min-height: clamp(540px, 70vh, 760px);
    display: grid;
    align-items: stretch;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    display: block;
    text-decoration: none;
  }

  .hero-media::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(26, 26, 26, 0.06) 0%, rgba(26, 26, 26, 0.18) 30%, rgba(26, 26, 26, 0.86) 100%);
  }

  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 360ms ease;
  }

  .hero-slot:hover .hero-media img {
    transform: scale(1.03);
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    align-self: end;
    padding: clamp(1.4rem, 4vw, 3.2rem);
    display: grid;
    gap: 1rem;
    color: rgb(255, 255, 255);
    max-width: 46rem;
  }

  .hero-topline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.9rem;
  }

  .hero-label {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.8);
  }

  .hero-category {
    color: rgb(255, 255, 255);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.74rem;
    font-weight: 700;
    opacity: 0.9;
  }

  .hero-category:hover {
    color: rgb(var(--accent));
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .hero-title {
    max-width: 12ch;
    font-size: clamp(3.1rem, 5.8vw, 5.8rem);
    line-height: 0.96;
    letter-spacing: -0.045em;
  }

  .hero-title a {
    color: rgb(255, 255, 255);
    text-decoration: none;
  }

  .hero-title a:hover {
    color: rgb(var(--accent));
  }

  .hero-excerpt {
    max-width: 60ch;
    color: rgba(255, 255, 255, 0.84);
    font-size: 1.08rem;
    line-height: 1.65;
  }

  .hero-meta {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 0.35rem;
  }

  .hero-author {
    max-width: 36rem;
  }

  .hero-date {
    color: rgba(255, 255, 255, 0.78);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    white-space: nowrap;
  }

  .latest-section {
    display: grid;
    gap: 1rem;
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
  }

  .section-meta {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .section-count {
    color: rgb(var(--muted));
    font-size: 0.86rem;
    letter-spacing: 0.04em;
  }

  .archive-link {
    color: rgb(var(--accent));
    text-decoration: none;
    text-transform: uppercase;
    font-size: 0.74rem;
    letter-spacing: 0.09em;
    font-weight: 700;
  }

  .archive-link:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .empty-copy {
    margin: 0;
    padding: 1rem;
    border: 1px dashed rgba(var(--border), 0.9);
    border-radius: 0.7rem;
    color: rgb(var(--muted));
    line-height: 1.55;
    background: rgba(var(--surface-strong), 0.5);
  }

  .latest-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .newsletter-panel {
    border-radius: 0;
    padding: 1.1rem;
    display: grid;
    gap: 0.65rem;
    max-width: 680px;
  }

  .newsletter-panel h2 {
    font-size: clamp(1.6rem, 3.1vw, 2.15rem);
    line-height: 1;
  }

  .newsletter-copy {
    color: rgb(var(--muted));
    line-height: 1.55;
    max-width: 55ch;
  }

  .newsletter-form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-items: center;
  }

  .newsletter-form input {
    flex: 1 1 260px;
    min-height: 42px;
    border: 1px solid rgba(var(--border), 0.95);
    border-radius: 0;
    padding: 0.58rem 0.72rem;
    background: rgba(var(--surface), 0.96);
    color: rgb(var(--ink));
    font: inherit;
  }

  .newsletter-form button {
    min-height: 42px;
    border: 1px solid rgba(var(--accent), 0.95);
    border-radius: 0;
    padding: 0.58rem 0.9rem;
    font: inherit;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: rgb(var(--paper));
    background: rgb(var(--accent));
    cursor: pointer;
  }

  .newsletter-form button[disabled] {
    opacity: 0.75;
    cursor: wait;
  }

  .newsletter-status {
    margin: 0;
    min-height: 1.2em;
    font-size: 0.9rem;
    color: rgb(var(--muted));
  }

  .newsletter-status.ok {
    color: #2c7b4b;
  }

  .newsletter-status.error {
    color: #b5382f;
  }

  @media (max-width: 1040px) {
    .latest-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .issue-head h1,
    .hero-title {
      max-width: none;
    }

    .section-head,
    .hero-meta {
      flex-direction: column;
      align-items: flex-start;
    }

    .section-meta {
      justify-content: flex-start;
    }

    .latest-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
