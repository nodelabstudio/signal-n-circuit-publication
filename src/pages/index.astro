---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE } from '../consts';
import { getHomepagePublicationPosts } from '../lib/publication';

const posts = await getHomepagePublicationPosts();
const [hero, ...rest] = posts;
const sidebar = rest.slice(0, 3);
const signalPosts = rest.slice(0, 2);
const gridPosts = [
  posts.find((post) => post.slug === 'the-best-vertical-ai-products-start-with-a-complaint-not-a-demo'),
  posts.find((post) => post.slug === 'release-notes-are-starting-to-matter-more-than-launch-events'),
  posts.find((post) => post.slug === 'small-operators-are-building-ai-systems-that-feel-more-like-services-than-software'),
].filter(Boolean);
const newsroomPosts = [
  posts.find((post) => post.slug === 'release-notes-are-starting-to-matter-more-than-launch-events'),
  posts.find((post) => post.slug === 'the-best-ai-builder-tools-are-starting-to-look-like-control-panels-not-chatbots'),
  posts.find((post) => post.slug === 'small-operators-are-building-ai-systems-that-feel-more-like-services-than-software'),
].filter(Boolean);
---

<!doctype html>
<html lang='en'>
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class='market-strip'>
        <span>Issue 0 • Local edition</span>
        <span>Coverage: builders, operators, tooling, ecosystems</span>
      </section>

      <section class='frontpage-intro'>
        <div>
          <p class='kicker'>Signal & Circuit</p>
          <h1 class='display-title'>Practical reporting on the businesses, builders, and operator workflows shaping AI deployment.</h1>
        </div>
        <div class='intro-stack'>
          <p class='intro-copy'>
            We care about what survives real operations: approvals, support load, maintenance, and deployment friction.
          </p>
          <p class='intro-subcopy'>
            {SITE_TAGLINE} Issue 0 — practical dispatches for AI operators, builders, and the people who keep the lights on.
          </p>
        </div>
      </section>

      <section class='hero-layout'>
        <article class='hero card'>
          <div class='hero-media'></div>
          <div class='hero-copy'>
            <p class='kicker'><a class='category-link' href={`/category/${hero.category}/`}>{hero.category.replace(/-/g, ' ')}</a></p>
            <h1>{hero.title}</h1>
            <p class='tagline'>{hero.excerpt}</p>
            <div class='meta'>
              <span>{hero.type}</span>
              <span>{hero.author}</span>
              <span>{hero.date}</span>
            </div>
            <a class='hero-link' href={`/articles/${hero.slug}/`}>Read the lead story</a>
          </div>
        </article>

        <aside class='sidebar'>
          <div class='sidebar-block card note-block'>
            <p class='kicker'>Editor&rsquo;s note</p>
            <h3>{SITE_TAGLINE}</h3>
            <p>
              Issue 0 of a publication tracking practical AI products, operators, and the
              quiet service economy building around them.
            </p>
          </div>
          <div class='sidebar-block card digest-block'>
            <div class='block-head'>
              <p class='kicker'>Analysis & opinion</p>
              <a href='/articles'>See archive</a>
            </div>
            <div class='sidebar-list'>
              {
                sidebar.map((post, index) => (
                  <a class='sidebar-item' href={`/articles/${post.slug}/`}>
                    <span>{String(index + 1).padStart(2, '0')} • {post.category.replace(/-/g, ' ')}</span>
                    <strong>{post.title}</strong>
                  </a>
                ))
              }
            </div>
          </div>
          <div class='sidebar-block card metrics-block'>
            <p class='kicker'>Coverage map</p>
            <div class='metrics-grid'>
              <div>
                <strong>{posts.length}</strong>
                <span>Stories live</span>
              </div>
              <div>
                <strong>10</strong>
                <span>Coverage lanes</span>
              </div>
              <div>
                <strong>Signal & Circuit</strong>
                <span>Issue 0</span>
              </div>
            </div>
          </div>
          <div class='sidebar-block card subscribe'>
            <p class='kicker'>Newsletter</p>
            <h3>Signal & Circuit</h3>
            <p>Practical dispatches on AI builders, operators, and the service economy. No fluff.</p>
            <form id='subscribe-form' class='subscribe-form' novalidate>
              <div class='subscribe-field'>
                <input
                  type='email'
                  name='email'
                  id='subscribe-email'
                  placeholder='your@email.com'
                  autocomplete='email'
                  required
                />
                <button type='submit' id='subscribe-btn'>Subscribe</button>
              </div>
              <p id='subscribe-msg' class='subscribe-msg' aria-live='polite'></p>
            </form>
          </div>
        </aside>
      </section>

      <section class='signal-strip'>
        <div class='signal-lead card'>
          <p class='kicker'>Signal board</p>
          <h2>What matters this week</h2>
          <p>
            The strongest opportunities are clustering around durable workflows, maintained automations, and
            service-heavy AI offerings that survive beyond the demo stage.
          </p>
        </div>
        <div class='signal-columns'>
          {
            signalPosts.map((post) => (
              <article class='signal-card card'>
                <p class='kicker'>{post.category.replace(/-/g, ' ')}</p>
                <h3><a href={`/articles/${post.slug}/`}>{post.title}</a></h3>
                <p>{post.excerpt}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class='section-head'>
        <div>
          <p class='kicker'>Latest coverage</p>
          <h2>What operators are learning in public</h2>
        </div>
        <a class='pill' href='/articles'>View all articles</a>
      </section>

      <section class='article-grid'>
        {
          gridPosts.map((post) => (
            <article class={`article-card card ${post.slug === 'release-notes-are-starting-to-matter-more-than-launch-events' ? 'release-card' : ''}`}>
              <div class='thumb'></div>
              <div class='article-copy'>
                <p class='kicker'><a class='category-link' href={`/category/${post.category}/`}>{post.category.replace(/-/g, ' ')}</a></p>
                <h3>
                  <a href={`/articles/${post.slug}/`}>{post.title}</a>
                </h3>
                <p>{post.excerpt}</p>
                <div class='meta'>
                  <span>{post.slug === 'release-notes-are-starting-to-matter-more-than-launch-events' ? 'release watch' : post.type}</span>
                  <span>{post.date}</span>
                </div>
              </div>
            </article>
          ))
        }
      </section>

      <section class='newsroom-grid'>
        <div class='newsroom-column card'>
          <div class='block-head'>
            <p class='kicker'>Newsroom mix</p>
            <a href='/articles'>Browse all</a>
          </div>
          <div class='newsroom-list'>
            {
              newsroomPosts.map((post) => (
                <article>
                  <span>{post.slug === 'release-notes-are-starting-to-matter-more-than-launch-events' ? 'release watch' : post.type} • {post.category.replace(/-/g, ' ')}</span>
                  <strong><a href={`/articles/${post.slug}/`}>{post.title}</a></strong>
                  <p>{post.excerpt}</p>
                </article>
              ))
            }
          </div>
        </div>

        <div class='secondary-grid'>
          <div class='briefs card'>
          <div class='block-head'>
            <p class='kicker'>Quick takes</p>
            <a href='/articles'>View all</a>
          </div>
          <div class='brief-list'>
            <article>
              <span>Field note</span>
              <strong>Small operators are wrapping AI workflows with enough support that customers can trust them in the field.</strong>
            </article>
            <article>
              <span>Watchlist</span>
              <strong>Builder tools that show logs, retries, and approval paths are starting to look more like control panels than chatbots.</strong>
            </article>
            <article>
              <span>Pattern</span>
              <strong>Release notes often reveal more about where a platform is really headed than the launch event that preceded them.</strong>
            </article>
          </div>
        </div>

          <div class='sponsor card'>
            <p class='ad-label'>Advertisement</p>
            <div class='sponsor-image'></div>
            <div class='sponsor-content'>
              <div class='sponsor-brand'>
                <span class='sponsor-logo'>⏱</span>
                <span class='sponsor-name'>BuildPulse</span>
              </div>
              <p class='sponsor-headline'>Ship faster with AI-assisted release tracking</p>
              <p class='sponsor-body'>Monitor changelogs, track deployment signals, and stay ahead of API changes before they break your stack.</p>
              <a class='sponsor-cta' href='/about'>Learn more</a>
            </div>
            <p class='ad-note'>Your brand here — available sponsorships from $199/mo</p>
          </div>
        </div>
      </section>
    </main>
    <Footer />
    <script>
      const form = document.getElementById('subscribe-form') as HTMLFormElement;
      const msg = document.getElementById('subscribe-msg') as HTMLParagraphElement;
      const btn = document.getElementById('subscribe-btn') as HTMLButtonElement;
      if (form && msg && btn) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const email = (document.getElementById('subscribe-email') as HTMLInputElement).value;
          msg.textContent = '';
          msg.className = 'subscribe-msg';
          btn.disabled = true;
          btn.textContent = '...';
          try {
            const res = await fetch('/api/subscribe', {
              method: 'POST',
              body: new URLSearchParams({ email }),
              headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            });
            const data = await res.json() as { error?: string };
            if (res.ok) {
              msg.textContent = 'Subscribed! Check your inbox.';
              msg.className = 'subscribe-msg success';
              form.reset();
            } else {
              msg.textContent = data.error ?? 'Something went wrong.';
              msg.className = 'subscribe-msg error';
            }
          } catch {
            msg.textContent = 'Could not reach the server. Try again.';
            msg.className = 'subscribe-msg error';
          } finally {
            btn.disabled = false;
            btn.textContent = 'Subscribe';
          }
        });
      }
    </script>
  </body>
</html>

<style>
  .market-strip {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 0 1rem;
    margin-bottom: 1.25rem;
    color: rgb(var(--muted));
    font-size: 0.82rem;
    border-bottom: 1px solid rgba(var(--border), 0.4);
  }

  .frontpage-intro {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.8fr);
    gap: 1.5rem;
    align-items: end;
    padding-bottom: 1.5rem;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid rgba(var(--border), 0.75);
  }

  .display-title {
    max-width: 12ch;
    font-size: clamp(3rem, 6.2vw, 5.8rem);
    line-height: 0.96;
    letter-spacing: -0.05em;
  }

  .intro-stack {
    display: grid;
    gap: 0.85rem;
    justify-self: end;
  }

  .intro-copy {
    max-width: 32ch;
    color: rgb(var(--ink));
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1.2rem;
    line-height: 1.35;
  }

  .intro-subcopy {
    max-width: 40ch;
    color: rgb(var(--muted));
    font-size: 1.03rem;
  }



  .hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.75fr) minmax(280px, 0.9fr);
    gap: 1.5rem;
    align-items: start;
  }

  .hero {
    overflow: hidden;
    box-shadow: 0 22px 60px rgba(var(--shadow), 0.1);
  }

  .hero-media {
    position: relative;
    min-height: 320px;
    background-image: url('/images/hero-article7.jpg');
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }

  .hero-media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(var(--ink), 0.15) 0%,
      rgba(var(--ink), 0.5) 100%
    );
  }

  .hero-copy {
    padding: 1.7rem;
    display: grid;
    gap: 1rem;
  }

  .category-link {
    text-decoration: none;
    color: inherit;
  }

  .tagline {
    font-size: 1.14rem;
    color: rgb(var(--muted));
    max-width: 58ch;
  }

  .hero-link {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.45rem;
    font-weight: 700;
    text-decoration: none;
    padding: 0.75rem 1rem;
    border-radius: 999px;
    background: rgba(var(--accent), 0.12);
  }

  .sidebar {
    display: grid;
    gap: 1rem;
  }

  .sidebar-block {
    padding: 1.25rem;
  }

  .note-block,
  .digest-block,
  .metrics-block {
    position: relative;
    overflow: hidden;
  }

  .block-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.95rem;
  }

  .block-head a {
    font-size: 0.86rem;
    text-decoration: none;
    color: rgb(var(--muted));
  }

  .sidebar-list {
    display: grid;
    gap: 0.85rem;
  }

  .sidebar-item {
    text-decoration: none;
    color: rgb(var(--ink));
    display: grid;
    gap: 0.25rem;
    padding-top: 0.85rem;
    border-top: 1px solid rgba(var(--border), 0.6);
  }

  .sidebar-item:first-child {
    padding-top: 0;
    border-top: none;
  }

  .sidebar-item strong {
    line-height: 1.22;
  }

  .sidebar-item span {
    color: rgb(var(--muted));
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
    margin-top: 0.8rem;
  }

  .metrics-grid div {
    display: grid;
    gap: 0.25rem;
    padding: 0.95rem 0.8rem;
    border-radius: 16px;
    background: rgba(var(--surface-strong), 0.62);
    border: 1px solid rgba(var(--border), 0.65);
  }

  .metrics-grid strong {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1.65rem;
    line-height: 1;
  }

  .metrics-grid span {
    font-size: 0.8rem;
    color: rgb(var(--muted));
  }

  .subscribe button {
    margin-top: 0.8rem;
    padding: 0.8rem 1rem;
    border: none;
    border-radius: 999px;
    background: rgb(var(--accent));
    color: white;
    font-weight: 700;
    cursor: pointer;
  }

  .subscribe-form {
    display: grid;
    gap: 0.6rem;
    margin-top: 0.8rem;
  }

  .subscribe-field {
    display: flex;
    gap: 0.5rem;
  }

  .subscribe-field input {
    flex: 1;
    min-width: 0;
    padding: 0.7rem 0.9rem;
    border: 1px solid rgba(var(--border), 0.8);
    border-radius: 999px;
    background: rgba(var(--surface-strong), 0.8);
    color: rgb(var(--ink));
    font-size: 0.9rem;
    outline: none;
  }

  .subscribe-field input:focus {
    border-color: rgb(var(--accent));
    box-shadow: 0 0 0 3px rgba(var(--accent), 0.12);
  }

  .subscribe-field button {
    margin-top: 0;
    padding: 0.7rem 1rem;
    border: none;
    border-radius: 999px;
    background: rgb(var(--accent));
    color: white;
    font-weight: 700;
    font-size: 0.88rem;
    cursor: pointer;
    white-space: nowrap;
  }

  .subscribe-field button:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .subscribe-msg {
    font-size: 0.83rem;
    margin: 0;
    min-height: 1.2em;
  }

  .subscribe-msg.success {
    color: rgb(22, 163, 74);
  }

  .subscribe-msg.error {
    color: rgb(220, 38, 38);
  }

  .signal-strip {
    display: grid;
    grid-template-columns: minmax(280px, 0.9fr) minmax(0, 1.6fr);
    gap: 1rem;
    margin-top: 1.15rem;
  }

  .signal-lead,
  .signal-card {
    padding: 1.45rem 1.5rem;
  }

  .signal-columns {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .signal-card {
    display: grid;
    gap: 0.55rem;
  }

  .signal-card a {
    color: rgb(var(--ink));
    text-decoration: none;
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
    margin: 2.8rem 0 1rem;
    padding-top: 0.65rem;
    border-top: 1px solid rgba(var(--border), 0.75);
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .release-card {
    background: linear-gradient(135deg, rgba(var(--surface), 0.98), rgba(var(--surface-strong), 0.92));
  }

  .release-card .thumb {
    min-height: 140px;
    background:
      linear-gradient(135deg, rgba(var(--ink), 0.88), rgba(var(--accent), 0.72)),
      radial-gradient(circle at top right, rgba(255,255,255,0.2), transparent 40%);
  }

  .release-card .thumb::before {
    inset: 1.1rem 1.1rem auto 1.1rem;
    height: 3.2rem;
    background: rgba(var(--bg), 0.94);
    box-shadow: none;
  }

  .release-card .thumb::after {
    left: 1.5rem;
    right: 1.5rem;
    bottom: 1.2rem;
    height: 0.55rem;
    box-shadow: 0 -0.9rem 0 rgba(255,255,255,0.16), 0 -1.8rem 0 rgba(255,255,255,0.08);
  }

  .newsroom-grid {
    display: grid;
    grid-template-columns: minmax(260px, 0.9fr) minmax(0, 1.7fr);
    gap: 1rem;
    margin-top: 1.1rem;
  }

  .newsroom-column {
    padding: 1.45rem 1.5rem;
  }

  .newsroom-list {
    display: grid;
    gap: 0.95rem;
    margin-top: 0.95rem;
  }

  .newsroom-list article {
    display: grid;
    gap: 0.35rem;
    padding-top: 0.95rem;
    border-top: 1px solid rgba(var(--border), 0.6);
  }

  .newsroom-list article:first-child {
    padding-top: 0;
    border-top: none;
  }

  .newsroom-list span {
    color: rgb(var(--muted));
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.09em;
  }

  .newsroom-list strong a {
    color: rgb(var(--ink));
    text-decoration: none;
    line-height: 1.22;
  }

  .secondary-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.75fr);
    gap: 1rem;
  }

  .briefs,
  .sponsor {
    padding: 1.45rem 1.5rem;
  }

  .brief-list {
    display: grid;
    gap: 0.95rem;
    margin-top: 0.95rem;
  }

  .brief-list article {
    display: grid;
    gap: 0.28rem;
    padding-top: 0.95rem;
    border-top: 1px solid rgba(var(--border), 0.6);
  }

  .brief-list article:first-child {
    padding-top: 0;
    border-top: none;
  }

  .brief-list span {
    color: rgb(var(--muted));
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.09em;
  }

  .brief-list strong {
    line-height: 1.28;
  }

  .sponsor {
    display: grid;
    gap: 0;
    padding: 0;
    background: rgba(var(--surface), 0.97);
    border: 1px solid rgba(var(--border), 0.7);
    overflow: hidden;
  }

  .sponsor-image {
    min-height: 160px;
    background-image: url('/images/buildpulse-ad.jpg');
    background-size: cover;
    background-position: top center;
  }

  .ad-label {
    margin: 0;
    padding: 0.35rem 0.9rem;
    background: rgba(var(--border), 0.35);
    color: rgb(var(--muted));
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-bottom: 1px solid rgba(var(--border), 0.5);
  }

  .sponsor-content {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 1.15rem 1.15rem 1rem;
    align-items: flex-start;
  }

  .sponsor-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .sponsor-logo {
    font-size: 1.3rem;
    line-height: 1;
  }

  .sponsor-name {
    font-weight: 700;
    font-size: 1rem;
    color: rgb(var(--ink));
  }

  .sponsor-headline {
    margin: 0;
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.2;
    color: rgb(var(--ink));
  }

  .sponsor-body {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.5;
    color: rgb(var(--muted));
  }

  .sponsor-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.3rem;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    background: rgb(var(--accent));
    color: white;
    font-size: 0.82rem;
    font-weight: 700;
    text-decoration: none;
    line-height: 1;
    width: auto;
    align-self: flex-start;
  }

  .ad-note {
    margin: 0;
    padding: 0.6rem 1.15rem;
    border-top: 1px solid rgba(var(--border), 0.4);
    font-size: 0.75rem;
    color: rgb(var(--muted));
    font-style: italic;
  }

  .article-card {
    overflow: hidden;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .article-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 22px 60px rgba(var(--shadow), 0.1);
  }

  .thumb {
    position: relative;
    min-height: 180px;
    background:
      linear-gradient(135deg, rgba(var(--surface-strong), 0.95), rgba(var(--border), 0.92)),
      radial-gradient(circle at top right, rgba(255,255,255,0.3), transparent 40%);
    border-bottom: 1px solid rgba(var(--border), 0.8);
  }

  .thumb::before {
    content: '';
    position: absolute;
    inset: 1rem;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(var(--bg), 0.95), rgba(255,255,255,0.7));
    border: 1px solid rgba(var(--border), 0.75);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.65);
  }

  .thumb::after {
    content: '';
    position: absolute;
    left: 1.8rem;
    right: 1.8rem;
    bottom: 1.6rem;
    height: 0.7rem;
