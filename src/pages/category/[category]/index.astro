---
import ArticleCard from '../../../../src/components/ArticleCard.astro';
import PublicationLayout from '../../../layouts/PublicationLayout.astro';
import { NAV_CATEGORIES } from '../../../consts';
import { getPublicationPosts } from '../../../lib/publication';

export const prerender = true;

export async function getStaticPaths() {
  return NAV_CATEGORIES.map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.params;
const posts = await getPublicationPosts();
const filteredPosts = posts.filter((post) => post.category === category);

if (!category) {
  return Astro.redirect('/articles');
}
---

<PublicationLayout
  title={`Category: ${category.replace(/-/g, ' ')}`}
  description={`Publication archive for ${category.replace(/-/g, ' ')}.`}
>
  <section class='archive-head'>
    <p class='kicker'>Category archive</p>
    <h1>{category.replace(/-/g, ' ')}</h1>
    <p>
      Focused coverage for this lane of the publication.
    </p>
  </section>

  <section class='archive-tools card'>
    <div>
      <p class='kicker'>Lane status</p>
      <strong>{filteredPosts.length > 0 ? 'Active coverage' : 'Planned coverage'}</strong>
    </div>
    <div>
      <p class='kicker'>Story count</p>
      <strong>{filteredPosts.length}</strong>
    </div>
    <div>
      <p class='kicker'>Editorial use</p>
      <strong>{filteredPosts.length > 0 ? 'Archive + discovery' : 'Roadmap signal'}</strong>
    </div>
  </section>

  {
    filteredPosts.length > 0 ? (
      <section class='archive-grid'>
        {filteredPosts.map((post) => <ArticleCard post={post} />)}
      </section>
    ) : (
      <section class='empty card'>
        <div class='empty-media' aria-hidden='true'></div>
        <div class='empty-copy'>
          <p class='kicker'>Planned lane</p>
          <h2>No stories published here yet</h2>
          <p>
            This coverage lane is currently quiet while new reporting is in development. New stories will appear here as they are published.
          </p>
          <p>
            For now, browse the <a href='/articles/'>current article archive</a> or return to the <a href='/'>front page</a>.
          </p>
        </div>
      </section>
    )
  }
</PublicationLayout>

<style>
  .archive-head {
    display: grid;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
    max-width: 70ch;
  }

  .archive-head h1 {
    font-size: clamp(3rem, 6vw, 5.4rem);
    max-width: 11ch;
  }

  .archive-head p:last-child {
    color: rgb(var(--muted));
    font-size: 1.08rem;
    line-height: 1.65;
    max-width: 55ch;
  }

  .archive-tools {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    padding: 1rem 1.15rem;
    margin-bottom: 1rem;
  }

  .archive-tools div {
    display: grid;
    gap: 0.25rem;
  }

  .archive-tools strong {
    font-family: 'Playfair Display', Georgia, 'Times New Roman', serif;
    font-size: 1.35rem;
    line-height: 1.1;
  }

  .archive-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .empty {
    overflow: hidden;
    border-radius: 0;
  }

  .empty-media {
    min-height: 180px;
    background:
      linear-gradient(135deg, rgba(var(--ink), 0.82), rgba(var(--accent), 0.72)),
      radial-gradient(circle at top right, rgba(255,255,255,0.2), transparent 40%),
      repeating-linear-gradient(
        135deg,
        rgba(255,255,255,0.05) 0,
        rgba(255,255,255,0.05) 16px,
        transparent 16px,
        transparent 32px
      );
    border-bottom: 1px solid rgba(var(--border), 0.85);
  }

  .empty-copy {
    padding: 1.5rem 1.5rem 1.6rem;
    display: grid;
    gap: 0.9rem;
  }

  .empty-copy h2 {
    font-size: clamp(2rem, 3vw, 3rem);
  }

  .empty-copy p {
    color: rgb(var(--muted));
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .archive-tools,
    .archive-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
