---
import PublicationLayout from '../../layouts/PublicationLayout.astro';
import { getPublicationPost, getPublicationPosts } from '../../lib/publication';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getPublicationPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = slug ? await getPublicationPost(slug) : undefined;
const approvedAuthorBio =
  'X Node Dev is a Senior Application Developer focused on local-first AI systems and workflow automation. He loves tinkering with new technology.';

if (!post) {
  return Astro.redirect('/articles');
}
---

<PublicationLayout title={post.title} description={post.excerpt}>
  <article class='article'>
    <header class='article-head'>
      <h1 class='article-title'>{post.title}</h1>
      <p class='article-excerpt'>{post.excerpt}</p>
      <div class='article-meta card'>
        <span class='meta-label'>{post.type}</span>
        <span class='byline'>By X Node Dev</span>
        <span class='date'>{post.date}</span>
      </div>

      <div class='tag-row'>
        {post.tags.map((tag) => (
          <a class='pill' href={`/tag/${tag}/`}>
            {tag}
          </a>
        ))}
      </div>
    </header>

    <section class='content-wrap'>
      <div class='prose card body-card'>
        <div class='article-rail'>
          <span>Lead analysis</span>
          <strong>{post.category.replace(/-/g, ' ')}</strong>
        </div>
        <p class='standfirst'>
          The commercial shape of AI agents is getting clearer: long-term value concentrates around installation, maintenance, oversight, and the human-readable systems that make automation survivable in the field.
        </p>
        {post.Content ? <post.Content /> : post.body?.split('\n\n').map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </section>

    <section class='author-endcap card'>
      <img src='/images/authors/xnodedev.jpg' alt='X Node Dev' loading='lazy' />
      <div class='author-endcap-copy'>
        <p class='kicker'>About the author</p>
        <p class='author-name'>X Node Dev</p>
        <p>{approvedAuthorBio}</p>
        <a class='author-link' href='https://x.com/x_node_dev' target='_blank' rel='noopener noreferrer'>@x_node_dev on X</a>
      </div>
    </section>
  </article>
</PublicationLayout>

<style>
  .article {
    display: grid;
    gap: 1.5rem;
  }

  .article-head {
    display: grid;
    gap: 1.35rem;
  }

  .article-title {
    font-size: clamp(2.15rem, 5.8vw, 4.2rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
    max-width: 16ch;
  }

  .article-excerpt {
    max-width: 62ch;
    color: rgb(var(--muted));
    font-size: 1.02rem;
    line-height: 1.64;
  }

  .article-meta {
    padding: 1.15rem 1.1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.25rem;
    border-radius: 0;
    color: rgb(var(--muted));
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
  }

  .meta-label,
  .date,
  .byline {
    display: block;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .content-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
  }

  .body-card {
    position: relative;
    padding: 1.8rem 1.8rem 1.5rem;
    max-width: 680px;
    margin: 0 auto;
    width: 100%;
    border-radius: 0;
  }

  .article-rail {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.2rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid rgba(var(--border), 0.7);
    color: rgb(var(--muted));
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
  }

  .standfirst {
    font-size: 1.24rem;
    line-height: 1.72;
    color: rgb(var(--ink));
    max-width: 34em;
    margin-bottom: 1.6rem;
  }

  .body-card p,
  .body-card li {
    margin-bottom: 1.35rem;
    max-width: 39em;
    font-size: 1.1rem;
    line-height: 1.82;
  }

  .body-card h2,
  .body-card h3 {
    margin: 2.1rem 0 1.25rem;
    line-height: 1.14;
  }

  .body-card h2 + p,
  .body-card h3 + p {
    margin-top: 0.4rem;
  }

  .body-card ul,
  .body-card ol {
    margin: 0 0 1.2rem 1.3rem;
    padding: 0;
  }

  .body-card blockquote {
    margin: 1rem 0 1.2rem 1rem;
    padding: 0.2rem 0 0.2rem 0.9rem;
    border-left: 3px solid rgba(var(--accent), 0.75);
    color: rgb(var(--muted));
    background: rgba(var(--surface-strong), 0.4);
  }

  .body-card em {
    font-style: italic;
  }

  .author-endcap {
    max-width: 680px;
    margin: 0 auto;
    width: 100%;
    border-radius: 0;
    padding: 1rem;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.9rem;
    align-items: center;
  }

  .author-endcap img {
    width: 64px;
    height: 64px;
    border-radius: 999px;
    object-fit: cover;
    border: 1px solid rgba(var(--border), 0.92);
  }

  .author-endcap-copy {
    display: grid;
    gap: 0.2rem;
    color: rgb(var(--muted));
  }

  .author-name {
    color: rgb(var(--ink));
    font-weight: 700;
    margin: 0;
  }

  .author-link {
    font-size: 0.88rem;
    text-decoration: none;
    color: rgb(var(--accent));
    font-weight: 600;
    width: fit-content;
  }

  .author-link:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  @media (max-width: 980px) {
    .article-meta {
      align-items: flex-start;
      flex-direction: column;
    }

    .author-endcap {
      grid-template-columns: 1fr;
      align-items: flex-start;
    }
  }
</style>
