---
import ArticleCard from '../../components/ArticleCard.astro';
import PublicationLayout from '../../layouts/PublicationLayout.astro';
import { getPublicationPosts } from '../../lib/publication';

const posts = await getPublicationPosts();
---

<PublicationLayout title='Articles' description='Browse the latest Signal & Circuit coverage.'>
  <section class='archive-head'>
    <p class='kicker'>Archive</p>
    <h1>All articles</h1>
    <p>
      Reporting on AI agents, LLM tooling, and the service businesses growing around practical automation.
    </p>
    <div class='archive-meta'>
      <p class='archive-count'>{posts.length} stories available</p>
      <a class='home-link' href='/'>Back to homepage</a>
    </div>
  </section>

  {
    posts.length > 0 ? (
      <section class='archive-grid'>
        {posts.map((post) => <ArticleCard post={post} />)}
      </section>
    ) : (
      <p class='empty-copy'>The archive is currently empty. Check back soon for the first Signal & Circuit issue.</p>
    )
  }
</PublicationLayout>

<style>
  .archive-head {
    display: grid;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
    max-width: 70ch;
  }

  .archive-head h1 {
    font-size: clamp(3rem, 6vw, 5.4rem);
    max-width: 11ch;
  }

  .archive-head p:last-child {
    color: rgb(var(--muted));
    font-size: 1.08rem;
    line-height: 1.65;
    max-width: 55ch;
  }

  .archive-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem;
    margin-top: 0.35rem;
  }

  .archive-count {
    margin: 0;
    color: rgb(var(--muted));
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .home-link {
    color: rgb(var(--accent));
    text-decoration: none;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    font-weight: 700;
  }

  .home-link:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .empty-copy {
    margin: 0;
    padding: 1rem;
    border: 1px dashed rgba(var(--border), 0.9);
    border-radius: 0.7rem;
    color: rgb(var(--muted));
    line-height: 1.55;
    background: rgba(var(--surface-strong), 0.5);
  }

  .archive-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  @media (max-width: 860px) {
    .archive-meta {
      justify-content: flex-start;
    }

    .archive-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
