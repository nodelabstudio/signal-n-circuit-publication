---
import AuthorBlock from '../../components/AuthorBlock.astro';
import HeroSlot from '../../components/HeroSlot.astro';
import PublicationLayout from '../../layouts/PublicationLayout.astro';
import { getPublicationPost, getPublicationPosts } from '../../lib/publication';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getPublicationPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = slug ? await getPublicationPost(slug) : undefined;

if (!post) {
  return Astro.redirect('/articles');
}
---

<PublicationLayout title={post.title} description={post.excerpt}>
  <article class='article'>
    <HeroSlot post={post} />

    <header class='article-head'>
      <div class='article-meta card'>
        <span class='meta-label'>{post.type}</span>
        <AuthorBlock name={post.author} image={post.authorImage} bio={post.authorBio} size='md' />
        <span class='date'>{post.date}</span>
      </div>

      <div class='tag-row'>
        {post.tags.map((tag) => (
          <a class='pill' href={`/tag/${tag}/`}>
            {tag}
          </a>
        ))}
      </div>
    </header>

    <section class='content-wrap'>
      <div class='prose card body-card'>
        <div class='article-rail'>
          <span>Lead analysis</span>
          <strong>{post.category.replace(/-/g, ' ')}</strong>
        </div>
        <p class='standfirst'>
          The commercial shape of AI agents is getting clearer: long-term value concentrates around installation, maintenance, oversight, and the human-readable systems that make automation survivable in the field.
        </p>
        {post.body?.split('\n\n').map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </section>
  </article>
</PublicationLayout>

<style>
  .article {
    display: grid;
    gap: 1.5rem;
  }

  .article-head {
    display: grid;
    gap: 1rem;
  }

  .article-meta {
    padding: 1.15rem 1.1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.25rem;
    border-radius: 0;
    color: rgb(var(--muted));
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
  }

  .meta-label,
  .date {
    display: block;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .content-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
  }

  .body-card {
    position: relative;
    padding: 1.8rem 1.8rem 1.5rem;
    max-width: 680px;
    margin: 0 auto;
    width: 100%;
    border-radius: 0;
  }

  .article-rail {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.2rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid rgba(var(--border), 0.7);
    color: rgb(var(--muted));
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
  }

  .standfirst {
    font-size: 1.24rem;
    line-height: 1.72;
    color: rgb(var(--ink));
    max-width: 34em;
  }

  .body-card p {
    margin-bottom: 1.35rem;
    max-width: 39em;
    font-size: 1.1rem;
    line-height: 1.82;
  }

  @media (max-width: 980px) {
    .article-meta {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
