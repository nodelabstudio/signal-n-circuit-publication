---
import PublicationLayout from '../../layouts/PublicationLayout.astro';
import { getPublicationPosts } from '../../lib/publication';

const posts = await getPublicationPosts();
---

<PublicationLayout title='Articles' description='Browse the latest publication coverage.'>
  <section class='page-head'>
    <p class='kicker'>Archive</p>
    <h1>All articles</h1>
    <p>Reporting on AI agents, LLM tooling, and the service businesses growing around practical automation.</p>
  </section>

  <section class='list'>
    {
      posts.map((post) => (
        <article class='row card'>
          <div class='row-media' aria-hidden='true'></div>
          <div class='row-copy'>
            <p class='kicker'><a class='category-link' href={`/category/${post.category}/`}>{post.category.replace(/-/g, ' ')}</a></p>
            <h2><a href={`/articles/${post.slug}/`}>{post.title}</a></h2>
            <p>{post.excerpt}</p>
            <div class='meta-block'>
              <span>{post.type}</span>
              <span>{post.author}</span>
              <span>{post.date}</span>
            </div>
          </div>
        </article>
      ))
    }
  </section>
</PublicationLayout>

<style>
  .page-head {
    display: grid;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
    max-width: 70ch;
  }

  .category-link {
    text-decoration: none;
    color: inherit;
  }

  .list {
    display: grid;
    gap: 1rem;
  }

  .row {
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(220px, 0.7fr) minmax(0, 1.4fr);
  }

  .row-media {
    min-height: 220px;
    background:
      linear-gradient(135deg, rgba(var(--surface-strong), 0.95), rgba(var(--border), 0.88)),
      radial-gradient(circle at top right, rgba(255,255,255,0.28), transparent 42%);
    border-right: 1px solid rgba(var(--border), 0.82);
    position: relative;
  }

  .row-media::before {
    content: '';
    position: absolute;
    inset: 1.15rem;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(var(--bg), 0.95), rgba(255,255,255,0.7));
    border: 1px solid rgba(var(--border), 0.72);
  }

  .row-media::after {
    content: '';
    position: absolute;
    left: 2rem;
    right: 2rem;
    bottom: 1.8rem;
    height: 0.7rem;
    border-radius: 999px;
    background: rgba(var(--accent), 0.18);
    box-shadow: 0 -1.15rem 0 rgba(var(--accent), 0.12), 0 -2.3rem 0 rgba(var(--ink), 0.08);
  }

  .row-copy {
    padding: 1.3rem;
    display: grid;
    gap: 0.9rem;
  }

  .row a {
    color: rgb(var(--ink));
    text-decoration: none;
  }

  .meta-block {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    color: rgb(var(--muted));
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
  }

  @media (max-width: 820px) {
    .row {
      grid-template-columns: 1fr;
    }

    .row-media {
      min-height: 180px;
      border-right: none;
      border-bottom: 1px solid rgba(var(--border), 0.82);
    }
  }
</style>
</PublicationLayout>

