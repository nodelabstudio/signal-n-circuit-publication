---
import PublicationLayout from '../layouts/PublicationLayout.astro';
---

<PublicationLayout title='Page not found' description='The page you requested could not be found.'>
  <section class='not-found card'>
    <p class='kicker'>404</p>
    <h1>Page not found</h1>
    <p>
      The link may be outdated or the page may have moved. You can continue browsing from the homepage or jump
      straight into the latest reporting.
    </p>
    <div class='actions'>
      <a class='btn' href='/'>Go to homepage</a>
      <a class='btn ghost' href='/articles/'>Browse articles</a>
    </div>
  </section>
</PublicationLayout>

<style>
  .not-found {
    max-width: 760px;
    margin: 2rem auto;
    padding: clamp(1.2rem, 3vw, 2rem);
    display: grid;
    gap: 0.9rem;
  }

  .not-found h1 {
    font-size: clamp(2.3rem, 5vw, 4rem);
    line-height: 0.95;
    max-width: 12ch;
  }

  .not-found p {
    color: rgb(var(--muted));
    line-height: 1.65;
    max-width: 56ch;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 0.4rem;
  }

  .btn {
    text-decoration: none;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(var(--border), 0.85);
    color: rgb(var(--ink));
    font-size: 0.86rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: rgba(var(--surface-strong), 0.75);
  }

  .btn:hover {
    color: rgb(var(--accent));
    border-color: rgba(var(--accent), 0.45);
  }

  .btn.ghost {
    background: transparent;
  }
</style>
