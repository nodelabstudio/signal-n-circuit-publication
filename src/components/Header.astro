---
import { NAV_CATEGORIES, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class='site-header'>
  <div class='topbar'>
    <div class='masthead'>
      <p class='eyebrow'>Field notes for AI operators</p>
      <div class='brand-row'>
        <a class='brand' href='/'>{SITE_TITLE}</a>
        <span class='dateline'>What shipped. What broke. What matters.</span>
      </div>
    </div>
    <nav class='primary-nav'>
      <HeaderLink href='/'>Home</HeaderLink>
      <HeaderLink href='/articles'>Articles</HeaderLink>
      <HeaderLink href='/about'>About</HeaderLink>
    </nav>

    <details class='mobile-menu'>
      <summary>Menu</summary>
      <nav aria-label='Mobile primary navigation'>
        <a href='/'>Home</a>
        <a href='/articles/'>Articles</a>
        <a href='/about/'>About</a>
      </nav>
    </details>
  </div>
  <nav class='category-nav' aria-label='Publication categories'>
    {
      NAV_CATEGORIES.map((category) => (
        <a href={`/category/${category}/`}>{category.replace(/-/g, ' ')}</a>
      ))
    }
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(var(--bg), 0.94);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(var(--border), 0.9);
  }

  .topbar {
    max-width: var(--page);
    margin: 0 auto;
    padding: 1rem 1.25rem 0.8rem;
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
  }

  .masthead {
    display: grid;
    gap: 0.45rem;
  }

  .brand-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem;
  }

  .eyebrow {
    margin: 0 0 0.3rem;
    color: rgb(var(--muted));
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    font-weight: 700;
  }

  .brand {
    font-family: 'Playfair Display', Georgia, 'Times New Roman', serif;
    font-size: 2rem;
    color: rgb(var(--ink));
    text-decoration: none;
    font-weight: 700;
    letter-spacing: -0.04em;
  }

  .dateline {
    color: rgb(var(--muted));
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .primary-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    justify-content: flex-end;
  }

  .primary-nav a {
    color: rgb(var(--ink));
    text-decoration: none;
    font-size: 0.95rem;
  }

  .mobile-menu {
    display: none;
  }

  .mobile-menu summary {
    list-style: none;
    cursor: pointer;
    user-select: none;
    border: 1px solid rgba(var(--border), 0.85);
    border-radius: 999px;
    padding: 0.36rem 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
    font-weight: 700;
    color: rgb(var(--ink));
    background: rgba(var(--surface-strong), 0.72);
  }

  .mobile-menu[open] summary {
    border-color: rgba(var(--accent), 0.5);
    color: rgb(var(--accent));
  }

  .mobile-menu nav {
    margin-top: 0.55rem;
    display: grid;
    gap: 0.35rem;
    padding: 0.55rem;
    border: 1px solid rgba(var(--border), 0.85);
    border-radius: 0.7rem;
    background: rgba(var(--surface), 0.98);
    min-width: 160px;
  }

  .mobile-menu nav a {
    color: rgb(var(--ink));
    text-decoration: none;
    font-size: 0.9rem;
    padding: 0.2rem 0;
  }

  .mobile-menu nav a:hover {
    color: rgb(var(--accent));
  }

  .category-nav {
    max-width: var(--page);
    margin: 0 auto;
    padding: 0 1.25rem 0.9rem;
    display: flex;
    gap: 0.9rem;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .category-nav::-webkit-scrollbar {
    display: none;
  }

  .category-nav a {
    text-decoration: none;
    color: rgb(var(--muted));
    text-transform: capitalize;
    white-space: nowrap;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
  }

  .brand:hover,
  .primary-nav a:hover,
  .category-nav a:hover {
    color: rgb(var(--accent));
  }

  @media (min-width: 1600px) {
    .topbar,
    .category-nav {
      margin-left: clamp(2rem, 4vw, 5.5rem);
      margin-right: auto;
    }
  }

  @media (max-width: 720px) {
    .topbar {
      align-items: center;
      justify-content: space-between;
      padding: 0.9rem 1.05rem 0.65rem;
      flex-direction: row;
    }

    .masthead {
      gap: 0.2rem;
    }

    .eyebrow {
      margin: 0;
    }

    .brand {
      font-size: 1.56rem;
    }

    .primary-nav {
      display: none;
    }

    .mobile-menu {
      display: block;
      margin-left: auto;
    }

    .category-nav {
      padding: 0 1.05rem 0.7rem;
    }
  }
</style>
