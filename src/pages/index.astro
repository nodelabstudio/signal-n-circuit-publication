---
import ArticleCard from '../components/ArticleCard.astro';
import PublicationLayout from '../layouts/PublicationLayout.astro';
import ReleaseWatch from '../components/ReleaseWatch.astro';
import { SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE } from '../consts';
import { getHomepagePublicationPosts, getPublicationPosts } from '../lib/publication';

const posts = await getHomepagePublicationPosts();
const allPosts = await getPublicationPosts();
const [lead, second, third, ...restPosts] = posts;
const compactStories = restPosts.slice(0, 4);
const latestPosts = restPosts.slice(4, 10);

const beats = [
  {
    label: 'Agent Ops',
    description: 'Approvals, handoffs, cron runs, and the reliability work behind useful agent systems.',
    categories: ['operator-stack', 'openclaw-ecosystem', 'infrastructure-profile'],
  },
  {
    label: 'Tooling DX',
    description: 'Developer tools, browser agents, MCP surfaces, and the workflows builders touch every day.',
    categories: ['tooling-dx', 'devtools'],
  },
  {
    label: 'Release Watch',
    description: 'Changelog lines that change pricing, limits, migration work, or production risk.',
    categories: ['release-watch', 'releases-changelog'],
  },
  {
    label: 'Service Models',
    description: 'How small operators package, sell, and maintain practical AI systems.',
    categories: ['ai-services', 'pain-points', 'analysis'],
  },
];

const beatCards = beats.map((beat) => {
  const stories = allPosts.filter((post) => beat.categories.includes(post.category));
  return {
    ...beat,
    story: stories[0],
    count: stories.length,
  };
});
---

<PublicationLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class='front-page'>
    <header class='issue-head'>
      <div>
        <p class='kicker'>Field notes for AI operators</p>
        <h1>What shipped. What broke. What matters next.</h1>
      </div>
      <div class='issue-card'>
        <p class='issue-label'>Today on Signal &amp; Circuit</p>
        <p>{SITE_TAGLINE}</p>
        <span>{allPosts.length} field reports in the archive</span>
      </div>
    </header>

    {lead && (
      <article class='lead-feature' aria-label='Lead story'>
        {lead.image && (
          <a class='lead-img-link' href={`/articles/${lead.slug}/`} aria-label={lead.title}>
            <img src={lead.image} alt={lead.title} loading='eager' />
          </a>
        )}
        <div class='lead-text'>
          <a class='section-label' href={`/category/${lead.category}/`}>{lead.category.replace(/-/g, ' ')}</a>
          <h2><a href={`/articles/${lead.slug}/`}>{lead.title}</a></h2>
          <p>{lead.excerpt}</p>
          <div class='impact-note'>
            <span>Why it matters</span>
            <p>Builders need the operational read: cost, reliability, migration work, and the parts that survive real users.</p>
          </div>
        </div>
      </article>
    )}

    {[second, third].filter(Boolean).length > 0 && (
      <section class='story-pair' aria-label='Top stories'>
        {[second, third].filter(Boolean).map((story) => (
          <article class='story-card'>
            {story.image && <img src={story.image} alt={story.title} loading='lazy' />}
            <div class='story-card-copy'>
              <a class='section-label' href={`/category/${story.category}/`}>{story.category.replace(/-/g, ' ')}</a>
              <h3><a href={`/articles/${story.slug}/`}>{story.title}</a></h3>
              <p>{story.excerpt}</p>
            </div>
          </article>
        ))}
      </section>
    )}

    {compactStories.length > 0 && (
      <section class='briefing-strip' aria-label='Latest briefing'>
        <p class='briefing-label'>Operator briefing</p>
        <div class='briefing-list'>
          {compactStories.map((post) => (
            <a href={`/articles/${post.slug}/`}>
              <span>{post.category.replace(/-/g, ' ')}</span>
              <strong>{post.title}</strong>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class='beat-rail' aria-label='Editorial beats'>
      <div class='section-head compact'>
        <div>
          <p class='kicker'>Beats</p>
          <h2>The map of the work</h2>
        </div>
        <p>Signal &amp; Circuit follows the systems layer behind AI adoption: tooling, releases, services, and operator scars.</p>
      </div>
      <div class='beat-grid'>
        {beatCards.map((beat) => (
          <article class='beat-card'>
            <span>{beat.count} stories</span>
            <h3>{beat.label}</h3>
            <p>{beat.description}</p>
            {beat.story ? <a href={`/articles/${beat.story.slug}/`}>Read latest</a> : <em>Building this beat</em>}
          </article>
        ))}
      </div>
    </section>

    <ReleaseWatch />

    <section class='newsletter-panel'>
      <div>
        <p class='kicker'>Operator brief</p>
        <h2>Get the signal when the tooling changes.</h2>
        <p class='newsletter-copy'>Practical dispatches on agents, releases, AI services, and the messy systems work that decides whether automation survives contact with Monday.</p>
      </div>
      <form id='newsletter-form' class='newsletter-form'>
        <input id='newsletter-email' name='email' type='email' placeholder='you@example.com' required />
        <button id='newsletter-submit' type='submit'>Subscribe</button>
      </form>
      <p id='newsletter-status' class='newsletter-status' aria-live='polite'></p>
    </section>

    <section class='latest-section'>
      <div class='section-head'>
        <div>
          <p class='kicker'>Latest field reports</p>
          <h2>More from the archive</h2>
        </div>
        <div class='section-meta'>
          <p class='section-count'>{allPosts.length} stories available</p>
          <a class='archive-link' href='/articles/'>Open the archive</a>
        </div>
      </div>

      {
        latestPosts.length > 0 ? (
          <div class='latest-grid'>
            {latestPosts.map((post) => <ArticleCard post={post} />)}
          </div>
        ) : (
          <p class='empty-copy'>New coverage lands here as soon as it is published.</p>
        )
      }
    </section>

    <section class='network-panel'>
      <div class='network-rule'></div>
      <div class='network-copy'>
        <p class='network-kicker'>Related project</p>
        <h2>Harbor &amp; Cross</h2>
        <p>Daily devotionals for Christian fathers from the same builder network. Kept separate, labeled clearly, and linked for readers who want it.</p>
        <a href='https://harborandcross.com' target='_blank' rel='noopener noreferrer'>Visit harborandcross.com</a>
      </div>
    </section>
  </section>

  <script is:inline>
    const form = document.getElementById('newsletter-form');
    const emailInput = document.getElementById('newsletter-email');
    const status = document.getElementById('newsletter-status');
    const submitBtn = document.getElementById('newsletter-submit');

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!emailInput || !status || !submitBtn) return;

      status.textContent = '';
      status.className = 'newsletter-status';
      submitBtn.setAttribute('disabled', 'true');
      submitBtn.textContent = 'Subscribing...';

      const body = new URLSearchParams({ email: emailInput.value.trim() });
      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body,
        });
        const data = await res.json().catch(() => ({}));

        if (res.ok) {
          status.textContent = 'Subscribed. Check your inbox for confirmation.';
          status.classList.add('ok');
          form.reset();
        } else {
          status.textContent = data.error || 'Could not subscribe right now.';
          status.classList.add('error');
        }
      } catch {
        status.textContent = 'Network error. Please try again.';
        status.classList.add('error');
      } finally {
        submitBtn.removeAttribute('disabled');
        submitBtn.textContent = 'Subscribe';
      }
    });
  </script>
</PublicationLayout>

<style>
  .front-page {
    display: grid;
    gap: clamp(1.7rem, 3vw, 3rem);
  }

  .issue-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 360px);
    gap: clamp(1.2rem, 4vw, 3rem);
    align-items: end;
    padding: 1.2rem 0 1.5rem;
    border-bottom: 1px solid rgba(var(--border), 0.95);
  }

  .issue-head h1 {
    max-width: 13ch;
    font-size: clamp(3.4rem, 8vw, 7.8rem);
    line-height: 0.88;
    letter-spacing: -0.07em;
  }

  .issue-card {
    display: grid;
    gap: 0.7rem;
    padding: 1rem;
    border-left: 4px solid rgb(var(--accent));
    background: rgba(var(--surface), 0.78);
    color: rgb(var(--muted));
  }

  .issue-label,
  .section-label,
  .briefing-label,
  .network-kicker {
    color: rgb(var(--accent));
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .issue-card span {
    color: rgb(var(--ink));
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .lead-feature {
    display: grid;
    grid-template-columns: minmax(320px, 1fr) minmax(420px, 1fr);
    min-height: 500px;
    border: 1px solid rgba(var(--border), 0.95);
    background: rgba(var(--surface), 0.84);
  }

  .lead-img-link {
    display: block;
    overflow: hidden;
    background: rgb(var(--surface-strong));
  }

  .lead-img-link img {
    width: 100%;
    height: 100%;
    min-height: 500px;
    object-fit: cover;
    transition: transform 420ms ease;
  }

  .lead-feature:hover .lead-img-link img {
    transform: scale(1.035);
  }

  .lead-text {
    display: grid;
    align-content: end;
    gap: 1rem;
    min-width: 0;
    padding: clamp(1.2rem, 3vw, 2.2rem);
  }

  .lead-text h2 {
    margin: 0;
    font-size: clamp(2.5rem, 5vw, 5.1rem);
    line-height: 0.91;
    letter-spacing: -0.06em;
  }

  .lead-text h2 a {
    color: rgb(var(--ink));
    overflow-wrap: break-word;
    text-decoration: none;
  }

  .lead-text h2 a:hover {
    color: rgb(var(--accent));
  }

  .lead-text > p {
    color: rgb(var(--muted));
    line-height: 1.65;
  }

  .impact-note {
    display: grid;
    gap: 0.4rem;
    margin-top: 0.3rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(var(--border), 0.8);
  }

  .impact-note span {
    color: rgb(var(--ink));
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .story-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .story-card {
    display: grid;
    border: 1px solid rgba(var(--border), 0.95);
    background: rgba(var(--surface), 0.84);
  }

  .story-card img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-bottom: 1px solid rgba(var(--border), 0.85);
  }

  .story-card-copy {
    display: grid;
    gap: 0.75rem;
    padding: 1rem 1.15rem 1.3rem;
    align-content: start;
  }

  .story-card-copy h3 {
    margin: 0;
    font-size: clamp(1.5rem, 2.8vw, 2.4rem);
    line-height: 1.02;
  }

  .story-card-copy h3 a {
    color: rgb(var(--ink));
    text-decoration: none;
  }

  .story-card-copy h3 a:hover {
    color: rgb(var(--accent));
  }

  .story-card-copy p {
    color: rgb(var(--muted));
    font-size: 0.94rem;
    line-height: 1.55;
  }

  .section-label,
  .briefing-label,
  .network-kicker {
    color: rgb(var(--accent));
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .beat-card,
  .newsletter-panel,
  .network-panel,
  .briefing-strip {
    border: 1px solid rgba(var(--border), 0.95);
    background: rgba(var(--surface), 0.84);
  }

  .briefing-strip {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 1rem;
    align-items: stretch;
    padding: 1rem;
  }

  .briefing-list {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
  }

  .briefing-list a {
    display: grid;
    gap: 0.4rem;
    padding: 0 1rem;
    border-left: 1px solid rgba(var(--border), 0.9);
    color: rgb(var(--ink));
    text-decoration: none;
  }

  .briefing-list span {
    color: rgb(var(--muted));
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .briefing-list strong {
    font-family: 'Playfair Display', Georgia, 'Times New Roman', serif;
    font-size: 1.1rem;
    line-height: 1.08;
  }

  .briefing-list a:hover strong {
    color: rgb(var(--accent));
  }

  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .section-head.compact {
    align-items: start;
    padding-top: 0.4rem;
  }

  .section-head h2 {
    margin: 0;
    max-width: 12ch;
    font-size: clamp(2.4rem, 5vw, 4.6rem);
    line-height: 0.94;
  }

  .section-meta {
    display: grid;
    justify-items: end;
    gap: 0.35rem;
  }

  .section-count {
    color: rgb(var(--muted));
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .archive-link {
    color: rgb(var(--accent));
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.09em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .beat-rail,
  .latest-section {
    display: grid;
    gap: 1rem;
  }

  .beat-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .beat-card {
    display: grid;
    gap: 0.7rem;
    min-height: 250px;
    padding: 1rem;
  }

  .beat-card span,
  .beat-card em {
    color: rgb(var(--muted));
    font-size: 0.7rem;
    font-style: normal;
    font-weight: 850;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .beat-card h3 {
    font-size: clamp(1.6rem, 2.6vw, 2.4rem);
  }

  .beat-card p {
    color: rgb(var(--muted));
    font-size: 0.94rem;
    line-height: 1.6;
  }

  .beat-card a {
    align-self: end;
    color: rgb(var(--accent));
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.09em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .newsletter-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 430px);
    gap: 1.2rem;
    align-items: end;
    padding: clamp(1.2rem, 3vw, 2rem);
    background:
      linear-gradient(135deg, rgba(var(--surface), 0.96), rgba(var(--surface-strong), 0.72)),
      radial-gradient(circle at top left, rgba(var(--accent), 0.12), transparent 30%);
  }

  .newsletter-panel h2 {
    max-width: 14ch;
    margin: 0.2rem 0 0.7rem;
  }

  .newsletter-form {
    display: flex;
    gap: 0.65rem;
  }

  .newsletter-form input {
    width: 100%;
    border: 1px solid rgba(var(--border), 0.95);
    background: rgb(var(--surface));
    color: rgb(var(--ink));
    padding: 0.82rem 0.9rem;
    font: inherit;
  }

  .newsletter-form button {
    border: 0;
    background: rgb(var(--accent));
    color: white;
    padding: 0.82rem 1rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .newsletter-form button:disabled {
    cursor: wait;
    opacity: 0.75;
  }

  .newsletter-status {
    grid-column: 2;
    min-height: 1.2rem;
    color: rgb(var(--muted));
    font-size: 0.9rem;
  }

  .newsletter-status.ok {
    color: rgb(34, 120, 76);
  }

  .newsletter-status.error {
    color: rgb(var(--accent));
  }

  .latest-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .empty-copy {
    padding: 1rem;
    border: 1px dashed rgba(var(--border), 0.9);
    color: rgb(var(--muted));
  }

  .network-panel {
    display: grid;
    grid-template-columns: 1fr minmax(280px, 430px);
    gap: 1.25rem;
    align-items: center;
    padding: 1rem;
    background: transparent;
  }

  .network-rule {
    height: 1px;
    background: rgba(var(--border), 0.95);
  }

  .network-copy {
    display: grid;
    gap: 0.55rem;
  }

  .network-copy h2 {
    margin: 0;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
  }

  .network-copy a {
    width: fit-content;
    color: rgb(var(--accent));
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.09em;
    text-decoration: none;
    text-transform: uppercase;
  }

  @media (max-width: 1080px) {
    .lead-feature,
    .issue-head,
    .newsletter-panel,
    .network-panel {
      grid-template-columns: 1fr;
    }

    .story-pair,
    .beat-grid,
    .briefing-list,
    .latest-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .newsletter-status {
      grid-column: 1;
    }
  }

  @media (max-width: 680px) {
    .issue-head h1 {
      font-size: clamp(3rem, 18vw, 4.5rem);
    }

    .lead-feature,
    .story-pair,
    .briefing-strip,
    .beat-grid,
    .briefing-list,
    .latest-grid {
      grid-template-columns: 1fr;
    }

    .lead-img-link img {
      min-height: 320px;
    }

    .story-card img {
      max-height: 260px;
    }

    .briefing-list a {
      padding: 0.85rem 0;
      border-left: 0;
      border-top: 1px solid rgba(var(--border), 0.9);
    }

    .section-head,
    .newsletter-form {
      align-items: flex-start;
      flex-direction: column;
    }

    .section-meta {
      justify-items: start;
    }
  }
</style>
